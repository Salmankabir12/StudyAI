---
import BaseLayout from '../layouts/BaseLayout.astro'
const message = Astro.url.searchParams.get('message') || ''
const error = Astro.url.searchParams.get('error') || ''
---
<BaseLayout title="Login">
  <div style="max-width:400px;margin:40px auto;">
    <div class="card">
      <h2 style="font-size:24px;font-weight:700;margin-bottom:4px;">Welcome back</h2>
      <p style="color:var(--text-secondary);font-size:14px;margin-bottom:24px;">Sign in to your StudyAI account</p>
      {message && <div style="padding:12px;border-radius:8px;background:#f0fdf4;color:#166534;font-size:14px;margin-bottom:16px;">{message}</div>}
      {error && <div style="padding:12px;border-radius:8px;background:#fef2f2;color:#991b1b;font-size:14px;margin-bottom:16px;">{error}</div>}
      <form method="POST" action="/api/auth/login">
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" required />
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" required />
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Sign In</button>
      </form>
      <p style="text-align:center;font-size:14px;color:var(--text-secondary);margin-top:20px;">
        Don't have an account? <a href="/register" style="color:var(--primary);text-decoration:none;font-weight:600;">Register</a>
      </p>
    </div>
  </div>
</BaseLayout>
