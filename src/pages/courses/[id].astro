---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getEnv } from '../../lib/db'
import { getSessionUser } from '../../lib/auth'

const env = getEnv(Astro)
const sessionId = Astro.cookies.get('session')?.value
const user = sessionId ? await getSessionUser(env.DB, sessionId) : null
if (!user) return Astro.redirect('/login')

const courseId = Number(Astro.params.id)
const course = await env.DB.prepare('SELECT * FROM courses WHERE id = ? AND user_id = ?').bind(courseId, user.id).first()
if (!course) return Astro.redirect('/dashboard')

const notes = await env.DB.prepare('SELECT * FROM notes WHERE course_id = ? ORDER BY created_at DESC').bind(courseId).all()
const quizzes = await env.DB.prepare('SELECT q.*, (SELECT COUNT(*) FROM questions WHERE quiz_id = q.id) as question_count FROM quizzes q WHERE q.course_id = ? ORDER BY q.created_at DESC').bind(courseId).all()
const suggestions = await env.DB.prepare('SELECT * FROM suggestions WHERE course_id = ? AND acted_upon = 0').bind(courseId).all()
---
<BaseLayout title={course.name as string} user={user}>
  <a href="/dashboard" style="color:var(--text-secondary);text-decoration:none;font-size:14px;display:inline-block;margin-bottom:20px;">← Back to Dashboard</a>

  <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:32px;flex-wrap:wrap;gap:12px;">
    <div>
      <h1 style="font-size:28px;font-weight:700;">{course.name}</h1>
      <p style="color:var(--text-secondary);font-size:14px;">
        {course.semester && `${course.semester} · `}{course.credits} credits · Target: {course.target_grade}
        {course.current_grade && ` · Current: ${course.current_grade}`}
      </p>
    </div>
    <div style="display:flex;gap:8px;">
      <a href={`/notes/new?course=${course.id}`} class="btn btn-primary btn-sm">+ Note</a>
    </div>
  </div>

  {suggestions.results.length > 0 && (
    <section style="margin-bottom:32px;">
      {suggestions.results.map((s: any) => (
        <div class="card" style="margin-bottom:8px;border-left:4px solid var(--accent);padding:16px;">
          <div style="display:flex;justify-content:space-between;align-items:start;">
            <div>
              <h3 style="font-size:14px;font-weight:600;margin-bottom:2px;">{s.title}</h3>
              <p style="font-size:13px;color:var(--text-secondary);">{s.description}</p>
            </div>
          </div>
        </div>
      ))}
    </section>
  )}

  <section style="margin-bottom:32px;">
    <h2 style="font-size:18px;font-weight:600;margin-bottom:12px;">📝 Notes</h2>
    {notes.results.length === 0 ? (
      <div class="card empty-state" style="padding:40px;">
        <p>No notes yet. Add your first note to generate AI summaries and quizzes.</p>
        <a href={`/notes/new?course=${course.id}`} class="btn btn-primary" style="margin-top:12px;">Add Note</a>
      </div>
    ) : (
      <div class="grid grid-2">
        {notes.results.map((n: any) => (
          <a href={`/notes/${n.id}`} class="card" style="text-decoration:none;color:inherit;cursor:pointer;display:block;">
            <h3 style="font-size:15px;font-weight:600;margin-bottom:4px;">{n.title}</h3>
            <p style="font-size:13px;color:var(--text-secondary);overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">
              {n.content.substring(0, 200)}
            </p>
            {n.ai_summary && <span class="tag" style="margin-top:8px;">AI Summary Ready</span>}
          </a>
        ))}
      </div>
    )}
  </section>

  <section>
    <h2 style="font-size:18px;font-weight:600;margin-bottom:12px;">🧠 Quizzes</h2>
    {quizzes.results.length === 0 ? (
      <div class="card empty-state" style="padding:40px;">
        <p>Add a note first, then generate a quiz from it.</p>
      </div>
    ) : (
      <div class="grid grid-2">
        {quizzes.results.map(async (q: any) => {
          const lastAttempt = await env.DB.prepare('SELECT * FROM attempts WHERE quiz_id = ? AND user_id = ? ORDER BY completed_at DESC LIMIT 1').bind(q.id, user.id).first()
          return (
            <a href={`/quizzes/${q.id}`} class="card" style="text-decoration:none;color:inherit;cursor:pointer;display:block;">
              <div style="display:flex;justify-content:space-between;align-items:start;">
                <h3 style="font-size:15px;font-weight:600;margin-bottom:4px;">{q.title}</h3>
                {lastAttempt && <span class="tag">{Math.round(Number(lastAttempt.score) / Number(lastAttempt.total) * 100)}%</span>}
              </div>
              <p style="font-size:13px;color:var(--text-secondary);">{q.question_count || 0} questions</p>
            </a>
          )
        })}
      </div>
    )}
  </section>
</BaseLayout>
