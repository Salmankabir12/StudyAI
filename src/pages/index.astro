---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getEnv } from '../lib/db'
import { getSessionUser } from '../lib/auth'
const env = getEnv(Astro)
const sessionId = Astro.cookies.get('session')?.value
const user = sessionId ? await getSessionUser(env.DB, sessionId) : null
---
<BaseLayout title="Study Smarter with AI" user={user}>
  <section style="text-align:center;padding:96px 0;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;display:flex;justify-content:center;align-items:center;pointer-events:none;">
      <div class="animate-pulse" style="width:500px;height:500px;border-radius:50%;background:linear-gradient(to right,#6366f1,#a855f7,#06b6d4);opacity:0.1;"></div>
    </div>
    <div style="display:inline-flex;padding:6px 14px;border-radius:999px;background:var(--surface-raised);border:1px solid var(--border);font-size:13px;color:var(--text-muted);margin-bottom:24px;position:relative;">
      AI-Powered Learning Platform
    </div>
    <h1 class="animate-gradient" style="font-size:52px;font-weight:700;line-height:1.1;margin-bottom:16px;background:linear-gradient(to right,#818cf8,#c084fc,#22d3ee,#818cf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
      Study Smarter with AI
    </h1>
    <p style="font-size:17px;color:var(--text-muted);max-width:520px;margin:0 auto 32px;line-height:1.7;">
      Turn your notes into summaries and quizzes instantly. Track courses, predict grades, and learn more effectively.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="/register" class="btn btn-primary" style="padding:12px 32px;font-size:15px;">Get Started Free</a>
      <a href="/login" class="btn btn-outline" style="padding:12px 32px;font-size:15px;">Sign In</a>
    </div>
  </section>

  <div class="section section-alt" style="padding:64px 24px;">
    <div class="constrained">
      <div style="text-align:center;margin-bottom:48px;">
        <h2 style="font-size:28px;font-weight:700;margin-bottom:8px;">Everything you need to study better</h2>
        <p style="font-size:15px;color:var(--text-muted);max-width:480px;margin:0 auto;">AI-powered tools to help you learn faster and track your progress.</p>
      </div>
      <div class="grid grid-3">
        <div class="card" style="text-align:center;position:relative;overflow:hidden;">
          <div style="position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(to right,#6366f1,#818cf8);"></div>
          <div style="width:48px;height:48px;border-radius:10px;background:linear-gradient(135deg,#6366f1,#818cf8);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h3 style="font-size:18px;margin-bottom:8px;font-weight:600;">AI Summaries</h3>
          <p style="font-size:14px;color:var(--text-muted);line-height:1.6;">Paste your notes and get instant AI summaries highlighting key concepts and definitions.</p>
        </div>
        <div class="card" style="text-align:center;position:relative;overflow:hidden;">
          <div style="position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(to right,#a855f7,#c084fc);"></div>
          <div style="width:48px;height:48px;border-radius:10px;background:linear-gradient(135deg,#a855f7,#c084fc);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          </div>
          <h3 style="font-size:18px;margin-bottom:8px;font-weight:600;">Smart Quizzes</h3>
          <p style="font-size:14px;color:var(--text-muted);line-height:1.6;">Auto-generated multiple choice questions to test your understanding of any topic.</p>
        </div>
        <div class="card" style="text-align:center;position:relative;overflow:hidden;">
          <div style="position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(to right,#06b6d4,#22d3ee);"></div>
          <div style="width:48px;height:48px;border-radius:10px;background:linear-gradient(135deg,#06b6d4,#22d3ee);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          </div>
          <h3 style="font-size:18px;margin-bottom:8px;font-weight:600;">Grade Predictor</h3>
          <p style="font-size:14px;color:var(--text-muted);line-height:1.6;">Track courses, set targets, and get what-if predictions for your academic goals.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="section" style="padding:64px 24px;">
    <div class="constrained">
      <div style="text-align:center;margin-bottom:48px;">
        <h2 style="font-size:28px;font-weight:700;margin-bottom:8px;">How it works</h2>
        <p style="font-size:15px;color:var(--text-muted);max-width:480px;margin:0 auto;">Three simple steps to supercharge your studying.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:32px;">
        <div style="text-align:center;">
          <div style="width:56px;height:56px;border-radius:14px;background:linear-gradient(135deg,#6366f1,#818cf8);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:22px;font-weight:700;color:white;">1</div>
          <h3 style="font-size:16px;font-weight:600;margin-bottom:6px;">Add a course</h3>
          <p style="font-size:14px;color:var(--text-muted);line-height:1.6;">Create courses for each subject you're studying and set your target grades.</p>
        </div>
        <div style="text-align:center;">
          <div style="width:56px;height:56px;border-radius:14px;background:linear-gradient(135deg,#a855f7,#c084fc);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:22px;font-weight:700;color:white;">2</div>
          <h3 style="font-size:16px;font-weight:600;margin-bottom:6px;">Paste your notes</h3>
          <p style="font-size:14px;color:var(--text-muted);line-height:1.6;">AI generates a concise summary and creates a quiz to test your knowledge.</p>
        </div>
        <div style="text-align:center;">
          <div style="width:56px;height:56px;border-radius:14px;background:linear-gradient(135deg,#06b6d4,#22d3ee);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:22px;font-weight:700;color:white;">3</div>
          <h3 style="font-size:16px;font-weight:600;margin-bottom:6px;">Track progress</h3>
          <p style="font-size:14px;color:var(--text-muted);line-height:1.6;">Monitor grades, predict outcomes, and identify areas to improve.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="section section-alt" style="padding:80px 24px;text-align:center;">
    <div class="constrained">
      <h2 style="font-size:28px;font-weight:700;margin-bottom:12px;">Ready to study smarter?</h2>
      <p style="font-size:15px;color:var(--text-muted);max-width:420px;margin:0 auto 28px;">Join now and let AI handle the heavy lifting.</p>
      <a href="/register" class="btn btn-primary" style="padding:14px 40px;font-size:16px;">Get Started Free</a>
    </div>
  </div>
</BaseLayout>